{
  "pipeline": {
    "name": "products_csv",
    "schedule": "@daily",
    "enabled": true
  },
  "extraction": {
    "input_prefix": "products_parquet",
    "format": "parquet",
    "options": {}
  },
  "transformation": {
    "steps": [
      {
        "name": "standardize_column_names"
      },
      {
        "name": "trim",
        "columns": ["product_name", "category"]
      },
      {
        "name": "cast_columns",
        "cast_map": {
          "price": "double"
        }
      },
      {
        "name": "drop_duplicates",
        "subset": ["id"]
      }
    ]
  },
  "loading": {
    "output_prefix": "products_parquet_transformed",
    "partition_cols": ["etl_run_date"]
  }
}

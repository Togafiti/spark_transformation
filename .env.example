# Copy this file to .env and update values for your environment
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_INPUT_PREFIX=products_parquet
MINIO_INPUT_FORMAT=
MINIO_INPUT_FILE_EXTENSIONS=
MINIO_OUTPUT_PREFIX=
# Optional: set fixed run id. Leave empty to auto-generate each run.
PIPELINE_RUN_ID=
# Optional: configure extraction/transforms/loading from JSON.
PIPELINE_CONFIG_DIR=config/pipelines
PIPELINE_CONFIG_PATH=
PIPELINE_CONFIG_JSON=
MINIO_OUTPUT_PARTITION_COLS=etl_run_date

# Run in terminal: python3 -c 'import secrets; print(secrets.token_hex(16))'
# Copy the generated value to AIRFLOW__WEBSERVER__SECRET_KEY
AIRFLOW__WEBSERVER__SECRET_KEY=
